const IND_COLOR = {
  'Drone':'#ff4d4d','GIS':'#4dff88','Hydrography':'#4da6ff',
  'Remote Sensing':'#ff9944','Engineering Survey':'#cc66ff','Land Survey':'#4477ff'
};
const IND_CHIP = {
  'Drone':'c-drone','GIS':'c-gis','Hydrography':'c-hydro',
  'Remote Sensing':'c-rs','Engineering Survey':'c-eng','Land Survey':'c-land'
};

let curFilter = 'All';
let map, mkLayer, htLayer, showMk=true, showHt=false;
let donutC, barC, curBM='dark';
let bmLayers = {};

// Starfield
(()=>{
  const cv = document.getElementById('bg-canvas');
  const cx = cv.getContext('2d');
  let W,H,stars=[];
  function init(){
    W=cv.width=window.innerWidth; H=cv.height=window.innerHeight;
    stars=[];
    for(let i=0;i<100;i++) stars.push({x:Math.random()*W,y:Math.random()*H,r:Math.random()*1.1+0.2,a:Math.random(),s:(Math.random()*0.004+0.001)*(Math.random()<.5?1:-1)});
  }
  function draw(){
    cx.clearRect(0,0,W,H);
    cx.fillStyle='#020810'; cx.fillRect(0,0,W,H);
    cx.strokeStyle='rgba(0,80,180,0.035)'; cx.lineWidth=1;
    for(let x=0;x<W;x+=56){cx.beginPath();cx.moveTo(x,0);cx.lineTo(x,H);cx.stroke();}
    for(let y=0;y<H;y+=56){cx.beginPath();cx.moveTo(0,y);cx.lineTo(W,y);cx.stroke();}
    stars.forEach(s=>{
      s.a+=s.s; if(s.a>1||s.a<0)s.s*=-1;
      cx.beginPath(); cx.arc(s.x,s.y,s.r,0,Math.PI*2);
      cx.fillStyle='rgba(120,200,255,'+(s.a*0.45)+')'; cx.fill();
    });
    requestAnimationFrame(draw);
  }
  init(); draw();
  window.addEventListener('resize',init);
})();

window.addEventListener('load',()=>{
  initMap(); initCharts(); buildSelect(); buildTable(); updateKPIs();
});

function initMap(){
  map = L.map('map',{center:[4.2,109.5],zoom:5,zoomControl:false});
  bmLayers.dark = L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{maxZoom:19,attribution:''});
  bmLayers.satellite = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{maxZoom:19,attribution:''});
  bmLayers.terrain = L.tileLayer('https://{s}.tile.opentopomap.org/{z}/{x}/{y}.png',{maxZoom:17,attribution:''});
  bmLayers.osm = L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',{maxZoom:19,attribution:''});
  bmLayers.dark.addTo(map);
  mkLayer = L.layerGroup().addTo(map);
  htLayer = L.layerGroup();
  renderMarkers(); renderHeat();
}

function renderMarkers(){
  mkLayer.clearLayers();
  filtered().forEach(c=>{
    const col = IND_COLOR[c.industry]||'#fff';
    const icon = L.divIcon({className:'',html:'<div style="width:11px;height:11px;border-radius:50%;background:'+col+';border:2px solid rgba(255,255,255,0.35);box-shadow:0 0 7px '+col+'99,0 0 14px '+col+'44;cursor:pointer"></div>',iconSize:[11,11],iconAnchor:[5,5]});
    const mk = L.marker([c.lat,c.lng],{icon});
    mk.bindPopup('<div class="pop"><div class="pop-name">'+c.name+'</div><div class="pop-row"><span>Industry</span><span>'+c.industry+'</span></div><div class="pop-row"><span>City</span><span>'+c.city+'</span></div><div class="pop-row"><span>State</span><span>'+c.state+'</span></div><div class="pop-web">'+c.web+'</div></div>',{className:'custom-popup',maxWidth:230});
    mkLayer.addLayer(mk);
  });
}

function renderHeat(){
  htLayer.clearLayers();
  DATA.forEach(c=>{
    const col=IND_COLOR[c.industry]||'#fff';
    htLayer.addLayer(L.circle([c.lat,c.lng],{radius:45000,fillColor:col,fillOpacity:0.07,color:col,weight:0}));
  });
}

function setBM(name,btn){
  document.querySelectorAll('.bm-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  map.removeLayer(bmLayers[curBM]); curBM=name; bmLayers[name].addTo(map);
}

function toggleLayer(t){
  if(t==='markers'){showMk=!showMk;document.getElementById('btn-mk').classList.toggle('active',showMk);showMk?mkLayer.addTo(map):map.removeLayer(mkLayer);}
  else{showHt=!showHt;document.getElementById('btn-ht').classList.toggle('active',showHt);showHt?htLayer.addTo(map):map.removeLayer(htLayer);}
}

function initCharts(){
  const dCtx=document.getElementById('donut').getContext('2d');
  const bCtx=document.getElementById('bar').getContext('2d');
  const id=getIndData(), sd=getStateData();
  donutC=new Chart(dCtx,{type:'doughnut',data:{labels:Object.keys(id),datasets:[{data:Object.values(id),backgroundColor:Object.keys(id).map(k=>IND_COLOR[k]+'99'),borderColor:Object.keys(id).map(k=>IND_COLOR[k]),borderWidth:1.5,hoverOffset:4}]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:'rgba(180,210,255,.6)',font:{size:8,family:'Space Grotesk'},boxWidth:9,padding:6}},tooltip:{callbacks:{labelColor:c=>({backgroundColor:Object.values(IND_COLOR)[c.dataIndex],borderColor:'transparent'})}}},cutout:'64%',animation:{duration:700}}});
  barC=new Chart(bCtx,{type:'bar',data:{labels:Object.keys(sd),datasets:[{data:Object.values(sd),backgroundColor:'rgba(0,212,255,.16)',borderColor:Object.keys(sd).map((_,i)=>i===0?'#00d4ff':'rgba(0,212,255,.35)'),borderWidth:1.5,borderRadius:3,borderSkipped:false}]},options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{color:'rgba(0,100,200,.06)',drawBorder:false},ticks:{color:'rgba(180,210,255,.4)',font:{size:8,family:"'JetBrains Mono',monospace"},maxTicksLimit:5},border:{display:false}},y:{grid:{display:false},ticks:{color:'rgba(180,210,255,.6)',font:{size:8,family:'Space Grotesk'}},border:{display:false}}},animation:{duration:500}}});
}

function getIndData(){const c={};(curFilter==='All'?DATA:DATA.filter(x=>x.industry===curFilter)).forEach(x=>{c[x.industry]=(c[x.industry]||0)+1;});return c;}
function getStateData(){const src=filtered();const c={};src.forEach(x=>{c[x.state]=(c[x.state]||0)+1;});return Object.fromEntries(Object.entries(c).sort((a,b)=>b[1]-a[1]).slice(0,7));}
function filtered(){return curFilter==='All'?DATA:DATA.filter(c=>c.industry===curFilter);}

function updateCharts(){
  const id=getIndData(),sd=getStateData();
  donutC.data.labels=Object.keys(id);donutC.data.datasets[0].data=Object.values(id);donutC.data.datasets[0].backgroundColor=Object.keys(id).map(k=>IND_COLOR[k]+'99');donutC.data.datasets[0].borderColor=Object.keys(id).map(k=>IND_COLOR[k]);donutC.update();
  barC.data.labels=Object.keys(sd);barC.data.datasets[0].data=Object.values(sd);barC.update();
}

function updateKPIs(){
  const src=filtered();
  document.getElementById('kpi-total').textContent=src.length;
  const sc={},ic={};src.forEach(c=>{sc[c.state]=(sc[c.state]||0)+1;ic[c.industry]=(ic[c.industry]||0)+1;});
  const ts=Object.entries(sc).sort((a,b)=>b[1]-a[1])[0];
  const ti=Object.entries(ic).sort((a,b)=>b[1]-a[1])[0];
  if(ts)document.getElementById('kpi-state').textContent=ts[0];
  if(ti)document.getElementById('kpi-ind').textContent=ti[0];
}

function setFilter(f,el){
  curFilter=f;
  document.querySelectorAll('.pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  renderMarkers();updateCharts();updateKPIs();buildTable();
  document.getElementById('ai-res').innerHTML='';
  document.getElementById('ai-qs-wrap').style.display='block';
}

function buildSelect(){
  const sel=document.getElementById('csel');
  DATA.forEach((c,i)=>{const o=document.createElement('option');o.value=i;o.textContent=c.name;sel.appendChild(o);});
}

function buildTable(){
  const src=filtered();
  document.getElementById('tbl-body').innerHTML=src.slice(0,10).map((c,i)=>'<tr style="cursor:pointer" onclick="focusCompany(''+c.name+'')"><td class="t-rank">'+String(i+1).padStart(2,'0')+'</td><td style="font-size:9px;color:var(--text-primary);font-weight:500">'+c.name+'</td><td><span class="chip '+IND_CHIP[c.industry]+'">'+c.industry.substring(0,4)+'</span></td><td style="font-size:8px;color:var(--text-muted)">'+c.state+'</td></tr>').join('');
}

function showCompany(idx){
  if(idx==='')return;
  const c=DATA[parseInt(idx)];if(!c)return;
  document.getElementById('c-profile').style.display='block';
  const init=c.name.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
  const col=IND_COLOR[c.industry]||'#fff';
  document.getElementById('p-logo').textContent=init;
  document.getElementById('p-logo').style.color=col;
  document.getElementById('p-name').textContent=c.name;
  const b=document.getElementById('p-badge');
  b.textContent=c.industry; b.className='chip '+IND_CHIP[c.industry];
  b.style.cssText='display:inline-block;margin-top:4px;';
  document.getElementById('p-loc').textContent=c.city+', '+c.state;
  document.getElementById('p-phone').textContent=c.phone;
  document.getElementById('p-email').textContent=c.email;
  document.getElementById('p-web').textContent=c.web;
  document.getElementById('p-desc').textContent=c.desc;
  map.flyTo([c.lat,c.lng],10,{duration:1.4});
}

function focusCompany(name){
  const idx=DATA.findIndex(c=>c.name===name);
  if(idx>=0){document.getElementById('csel').value=idx;showCompany(idx);}
}

function runAI(){quickSearch(document.getElementById('ai-inp').value);}

function quickSearch(q){
  document.getElementById('ai-inp').value=q;
  if(!q.trim())return;
  const words=q.toLowerCase().split(' ');
  const res=DATA.filter(c=>{
    const hay=(c.name+' '+c.industry+' '+c.city+' '+c.state+' '+c.desc).toLowerCase();
    return words.some(w=>w.length>1&&hay.includes(w));
  }).slice(0,6);
  document.getElementById('ai-qs-wrap').style.display='none';
  const d=document.getElementById('ai-res');
  d.innerHTML=res.length?res.map(c=>'<div class="ai-r" onclick="focusCompany(''+c.name+'')"><span class="chip '+IND_CHIP[c.industry]+'">'+c.industry.substring(0,3)+'</span><div><div class="ai-r-name">'+c.name+'</div><div class="ai-r-meta">'+c.city+' &middot; '+c.state+'</div></div></div>').join(''):'<div style="font-size:9px;color:var(--text-muted);padding:8px 0">No results. Try different keywords.</div>';
}

function refreshData(){
  const b=document.querySelector('.btn');b.textContent='&#8635; Loading…';
  setTimeout(()=>{updateKPIs();b.innerHTML='&#8635; Refresh';},700);
}
</script>
