
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Geospatial Industry Dashboard — Malaysia</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --glass-bg:rgba(8,15,28,.72);--glass-border:rgba(100,200,255,.12);
  --panel-bg:rgba(6,12,24,.92);--accent-cyan:#00d4ff;--accent-green:#00ff9d;
  --accent-amber:#ffb547;--text-primary:#e8f4ff;--text-secondary:rgba(180,210,255,.65);
  --text-muted:rgba(120,160,200,.45);--grid-line:rgba(100,160,255,.07);
  --font:'Space Grotesk',sans-serif;--mono:'JetBrains Mono',monospace;
}
html,body{height:100%;overflow:hidden;background:#020810;color:var(--text-primary);font-family:var(--font);}
#bg-canvas{position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;pointer-events:none;}

/* HEADER */
#header{position:relative;z-index:100;display:flex;align-items:center;justify-content:space-between;
  padding:0 20px;height:50px;background:rgba(4,10,22,.97);
  border-bottom:1px solid var(--glass-border);flex-shrink:0;}
.hdr-logo{display:flex;align-items:center;gap:9px;font-size:11px;font-weight:600;
  color:var(--accent-cyan);letter-spacing:.1em;text-transform:uppercase;}
.logo-box{width:26px;height:26px;background:linear-gradient(135deg,#003d5c,#006080);
  border:1px solid var(--accent-cyan);border-radius:5px;display:flex;align-items:center;
  justify-content:center;font-size:13px;}
.hdr-title{font-size:13px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;
  color:var(--text-primary);text-align:center;}
.hdr-title em{color:var(--accent-cyan);font-style:normal;}
.hdr-right{display:flex;align-items:center;gap:10px;}
.dot-live{width:6px;height:6px;border-radius:50%;background:var(--accent-green);animation:pulse 2s infinite;flex-shrink:0;}
@keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,255,157,.4)}50%{opacity:.7;box-shadow:0 0 0 4px rgba(0,255,157,0)}}
.btn{background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.25);color:var(--accent-cyan);
  border-radius:6px;padding:4px 12px;font-size:10px;font-family:var(--font);cursor:pointer;
  letter-spacing:.06em;text-transform:uppercase;transition:all .2s;}
.btn:hover{background:rgba(0,212,255,.18);border-color:var(--accent-cyan);}

/* KPI */
#kpi-bar{position:relative;z-index:100;display:grid;grid-template-columns:repeat(4,1fr);gap:6px;
  padding:6px 14px;background:rgba(4,10,22,.85);border-bottom:1px solid var(--glass-border);flex-shrink:0;}
.kpi{background:rgba(0,30,60,.5);border:1px solid rgba(0,150,200,.15);border-radius:7px;
  padding:7px 11px;display:flex;align-items:center;gap:9px;position:relative;overflow:hidden;transition:border-color .2s;}
.kpi:hover{border-color:rgba(0,212,255,.35);}
.kpi::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent-cyan),transparent);opacity:.35;}
.kpi-ico{font-size:18px;flex-shrink:0;}
.kpi-v{font-size:18px;font-weight:700;color:var(--text-primary);line-height:1;font-family:var(--mono);}
.kpi-l{font-size:9px;color:var(--text-secondary);letter-spacing:.08em;text-transform:uppercase;margin-top:1px;}

/* FILTER */
#fbar{position:relative;z-index:100;display:flex;align-items:center;gap:10px;
  padding:5px 14px;background:rgba(4,10,22,.8);border-bottom:1px solid var(--glass-border);flex-shrink:0;}
.flbl{font-size:9px;color:var(--text-secondary);text-transform:uppercase;letter-spacing:.1em;white-space:nowrap;}
.pills{display:flex;gap:5px;flex-wrap:wrap;}
.pill{padding:3px 10px;border-radius:20px;font-size:9px;font-weight:500;
  border:1px solid rgba(100,160,255,.2);background:rgba(0,20,50,.5);color:var(--text-secondary);
  cursor:pointer;transition:all .18s;letter-spacing:.04em;white-space:nowrap;}
.pill:hover{border-color:rgba(0,212,255,.5);color:var(--text-primary);}
.pill.active{background:rgba(0,212,255,.12);border-color:var(--accent-cyan);color:var(--accent-cyan);}

/* MAIN */
#main{display:grid;grid-template-columns:238px 1fr 258px;flex:1;min-height:0;position:relative;z-index:50;}

/* PANELS */
.panel{background:var(--panel-bg);border-right:1px solid var(--glass-border);
  overflow-y:auto;overflow-x:hidden;display:flex;flex-direction:column;}
.panel:last-child{border-right:none;border-left:1px solid var(--glass-border);}
.panel::-webkit-scrollbar{width:3px;}
.panel::-webkit-scrollbar-thumb{background:rgba(0,212,255,.2);border-radius:2px;}
.sec{padding:11px 13px;border-bottom:1px solid var(--glass-border);}
.sec.grow{flex:1;border-bottom:none;}
.sec-title{font-size:9px;font-weight:700;color:var(--accent-cyan);text-transform:uppercase;
  letter-spacing:.15em;display:flex;align-items:center;gap:6px;margin-bottom:9px;}
.sec-title::after{content:'';flex:1;height:1px;background:var(--glass-border);}

/* CHARTS */
.chart-wrap{position:relative;}

/* AI */
.ai-row{display:flex;gap:5px;align-items:center;margin-bottom:7px;}
.ai-inp{flex:1;background:rgba(0,20,50,.6);border:1px solid rgba(0,150,200,.2);border-radius:5px;
  padding:5px 9px;font-size:10px;color:var(--text-primary);font-family:var(--font);outline:none;transition:border-color .2s;}
.ai-inp:focus{border-color:var(--accent-cyan);}
.ai-inp::placeholder{color:var(--text-muted);}
.ai-go{background:rgba(0,212,255,.1);border:1px solid rgba(0,212,255,.3);color:var(--accent-cyan);
  border-radius:5px;padding:5px 8px;font-size:11px;cursor:pointer;transition:all .15s;}
.ai-go:hover{background:rgba(0,212,255,.2);}
.ai-qs{display:flex;flex-direction:column;gap:3px;margin-bottom:7px;}
.qs-lbl{font-size:8px;color:var(--text-muted);letter-spacing:.06em;margin-bottom:2px;}
.ai-r{background:rgba(0,30,60,.5);border:1px solid rgba(0,150,200,.15);border-radius:5px;
  padding:6px 9px;cursor:pointer;display:flex;align-items:center;gap:7px;transition:all .15s;}
.ai-r:hover{border-color:var(--accent-cyan);background:rgba(0,50,90,.5);}
.ai-r-name{font-size:10px;font-weight:500;color:var(--text-primary);}
.ai-r-meta{font-size:8px;color:var(--text-secondary);letter-spacing:.04em;}
.chip{font-size:8px;padding:2px 6px;border-radius:10px;border:1px solid;font-weight:600;
  text-transform:uppercase;letter-spacing:.05em;flex-shrink:0;}
.c-drone{color:#ff4d4d;border-color:rgba(255,77,77,.4);background:rgba(255,77,77,.08);}
.c-gis{color:#4dff88;border-color:rgba(77,255,136,.4);background:rgba(77,255,136,.08);}
.c-hydro{color:#4da6ff;border-color:rgba(77,166,255,.4);background:rgba(77,166,255,.08);}
.c-rs{color:#ff9944;border-color:rgba(255,153,68,.4);background:rgba(255,153,68,.08);}
.c-eng{color:#cc66ff;border-color:rgba(204,102,255,.4);background:rgba(204,102,255,.08);}
.c-land{color:#4477ff;border-color:rgba(68,119,255,.4);background:rgba(68,119,255,.08);}

/* MAP */
#map-panel{position:relative;overflow:hidden;}
#map{width:100%;height:100%;}
.leaflet-container{background:#060e1e!important;}
.map-ctrls{position:absolute;top:10px;right:10px;z-index:1000;display:flex;flex-direction:column;gap:4px;}
.bm-btn{background:rgba(4,10,22,.92);border:1px solid var(--glass-border);color:var(--text-secondary);
  border-radius:5px;padding:4px 9px;font-size:9px;cursor:pointer;font-family:var(--font);
  letter-spacing:.05em;transition:all .15s;white-space:nowrap;}
.bm-btn:hover,.bm-btn.active{border-color:var(--accent-cyan);color:var(--accent-cyan);}
.layer-btns{position:absolute;bottom:14px;left:10px;z-index:1000;display:flex;gap:5px;}
.lay-btn{background:rgba(4,10,22,.92);border:1px solid var(--glass-border);color:var(--text-secondary);
  border-radius:5px;padding:4px 10px;font-size:9px;cursor:pointer;font-family:var(--font);
  letter-spacing:.06em;text-transform:uppercase;transition:all .15s;}
.lay-btn.active{border-color:var(--accent-cyan);color:var(--accent-cyan);}
.custom-popup .leaflet-popup-content-wrapper{background:rgba(4,12,28,.97);border:1px solid var(--glass-border);
  border-radius:9px;box-shadow:0 4px 24px rgba(0,0,0,.6);padding:0;}
.custom-popup .leaflet-popup-tip{background:rgba(4,12,28,.97);}
.pop{padding:11px 13px;font-family:var(--font);min-width:175px;}
.pop-name{font-size:12px;font-weight:600;color:var(--text-primary);margin-bottom:4px;}
.pop-row{display:flex;gap:6px;font-size:9px;color:var(--text-secondary);margin:2px 0;align-items:center;}
.pop-row span:first-child{color:var(--text-muted);min-width:48px;}
.pop-web{display:inline-block;margin-top:7px;padding:3px 9px;border-radius:4px;
  background:rgba(0,212,255,.08);border:1px solid rgba(0,212,255,.25);
  color:var(--accent-cyan);font-size:8px;letter-spacing:.06em;text-transform:uppercase;}

/* RIGHT PANEL */
.csel{width:100%;background:rgba(0,20,50,.6);border:1px solid rgba(0,150,200,.2);
  border-radius:5px;padding:5px 9px;font-size:10px;color:var(--text-primary);
  font-family:var(--font);outline:none;cursor:pointer;}
.csel option{background:#050d1f;}
.c-profile{background:rgba(0,25,55,.4);border:1px solid rgba(0,150,200,.12);
  border-radius:7px;padding:11px;margin-top:9px;}
.p-logo{width:40px;height:40px;border-radius:7px;display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:700;margin-bottom:7px;background:rgba(0,40,80,.6);
  border:1px solid rgba(0,150,200,.2);}
.p-name{font-size:12px;font-weight:600;color:var(--text-primary);}
.p-detail{display:flex;flex-direction:column;gap:3px;margin-top:9px;}
.d-row{display:flex;gap:5px;font-size:9px;color:var(--text-secondary);}
.d-lbl{color:var(--text-muted);min-width:44px;flex-shrink:0;}
.p-desc{font-size:9px;color:var(--text-secondary);line-height:1.6;margin-top:7px;
  padding-top:7px;border-top:1px solid var(--glass-border);}
.ctbl{width:100%;border-collapse:collapse;font-size:9px;}
.ctbl th{color:var(--text-muted);font-weight:600;letter-spacing:.08em;text-transform:uppercase;
  font-size:8px;padding:4px 7px;border-bottom:1px solid var(--glass-border);text-align:left;}
.ctbl td{padding:5px 7px;border-bottom:1px solid rgba(0,100,150,.06);color:var(--text-secondary);}
.ctbl tr:hover td{background:rgba(0,50,100,.2);}
.t-rank{color:var(--text-muted);font-family:var(--mono);font-size:8px;}
.leaflet-control-zoom{display:none;}
body{display:flex;flex-direction:column;height:100vh;}
</style>
</head>
<body>
<canvas id="bg-canvas"></canvas>

<div id="header">
  <div class="hdr-logo">
    <div class="logo-box">&#127760;</div>
    GeoIntel MY
  </div>
  <div class="hdr-title"><em>Geospatial</em> Industry Dashboard &mdash; Malaysia</div>
  <div class="hdr-right">
    <div class="dot-live"></div>
    <span style="font-size:9px;color:var(--text-secondary);letter-spacing:.06em;">LIVE</span>
    <button class="btn" onclick="refreshData()">&#8635; Refresh</button>
  </div>
</div>

<div id="kpi-bar">
  <div class="kpi"><div class="kpi-ico">&#127970;</div><div><div class="kpi-v" id="kpi-total">42</div><div class="kpi-l">Total Companies</div></div></div>
  <div class="kpi"><div class="kpi-ico">&#128202;</div><div><div class="kpi-v">6</div><div class="kpi-l">Industries</div></div></div>
  <div class="kpi"><div class="kpi-ico">&#128205;</div><div><div class="kpi-v" id="kpi-state">Selangor</div><div class="kpi-l">Top State</div></div></div>
  <div class="kpi"><div class="kpi-ico">&#128640;</div><div><div class="kpi-v" id="kpi-ind">GIS</div><div class="kpi-l">Top Industry</div></div></div>
</div>

<div id="fbar">
  <span class="flbl">Filter Industry</span>
  <div class="pills" id="pills">
    <div class="pill active" onclick="setFilter('All',this)">All</div>
    <div class="pill" onclick="setFilter('Drone',this)">Drone</div>
    <div class="pill" onclick="setFilter('GIS',this)">GIS</div>
    <div class="pill" onclick="setFilter('Hydrography',this)">Hydrography</div>
    <div class="pill" onclick="setFilter('Remote Sensing',this)">Remote Sensing</div>
    <div class="pill" onclick="setFilter('Engineering Survey',this)">Eng. Survey</div>
    <div class="pill" onclick="setFilter('Land Survey',this)">Land Survey</div>
  </div>
</div>

<div id="main">
  <!-- LEFT -->
  <div class="panel">
    <div class="sec">
      <div class="sec-title">Industry Distribution</div>
      <div class="chart-wrap" style="height:155px"><canvas id="donut"></canvas></div>
    </div>
    <div class="sec">
      <div class="sec-title">Companies by State</div>
      <div class="chart-wrap" style="height:175px"><canvas id="bar"></canvas></div>
    </div>
    <div class="sec grow">
      <div class="sec-title">AI Career Assistant</div>
      <div class="ai-row">
        <input class="ai-inp" id="ai-inp" placeholder="Which companies use drone mapping?" onkeydown="if(event.key==='Enter')runAI()"/>
        <button class="ai-go" onclick="runAI()">&#8594;</button>
      </div>
      <div id="ai-qs-wrap">
        <div class="ai-qs">
          <div class="qs-lbl">QUICK QUERIES</div>
          <div class="ai-r" onclick="quickSearch('drone mapping')"><span style="font-size:9px;color:var(--text-secondary)">Drone mapping companies &rarr;</span></div>
          <div class="ai-r" onclick="quickSearch('GIS Kuala Lumpur')"><span style="font-size:9px;color:var(--text-secondary)">GIS firms in KL &rarr;</span></div>
          <div class="ai-r" onclick="quickSearch('remote sensing')"><span style="font-size:9px;color:var(--text-secondary)">Remote sensing companies &rarr;</span></div>
          <div class="ai-r" onclick="quickSearch('land survey Johor')"><span style="font-size:9px;color:var(--text-secondary)">Land survey in Johor &rarr;</span></div>
        </div>
      </div>
      <div id="ai-res"></div>
    </div>
  </div>

  <!-- MAP -->
  <div id="map-panel">
    <div id="map"></div>
    <div class="map-ctrls">
      <button class="bm-btn active" onclick="setBM('dark',this)">Dark</button>
      <button class="bm-btn" onclick="setBM('satellite',this)">Satellite</button>
      <button class="bm-btn" onclick="setBM('terrain',this)">Terrain</button>
      <button class="bm-btn" onclick="setBM('osm',this)">OSM</button>
    </div>
    <div class="layer-btns">
      <button class="lay-btn active" id="btn-mk" onclick="toggleLayer('markers')">&#9679; Markers</button>
      <button class="lay-btn" id="btn-ht" onclick="toggleLayer('heat')">&#9830; Heatmap</button>
    </div>
  </div>

  <!-- RIGHT -->
  <div class="panel">
    <div class="sec">
      <div class="sec-title">Company Explorer</div>
      <select class="csel" id="csel" onchange="showCompany(this.value)">
        <option value="">&#8212; Select Company &#8212;</option>
      </select>
      <div id="c-profile" style="display:none">
        <div class="c-profile">
          <div class="p-logo" id="p-logo">AG</div>
          <div class="p-name" id="p-name">Aerodyne Group</div>
          <span class="chip" id="p-badge" style="margin-top:4px;display:inline-block">Drone</span>
          <div class="p-detail">
            <div class="d-row"><span class="d-lbl">Location</span><span id="p-loc"></span></div>
            <div class="d-row"><span class="d-lbl">Phone</span><span id="p-phone"></span></div>
            <div class="d-row"><span class="d-lbl">Email</span><span id="p-email"></span></div>
            <div class="d-row"><span class="d-lbl">Web</span><span id="p-web" style="color:var(--accent-cyan)"></span></div>
          </div>
          <div class="p-desc" id="p-desc"></div>
        </div>
      </div>
    </div>
    <div class="sec grow" style="overflow:auto">
      <div class="sec-title">Top Companies</div>
      <table class="ctbl">
        <thead><tr><th>#</th><th>Company</th><th>Industry</th><th>State</th></tr></thead>
        <tbody id="tbl-body"></tbody>
      </table>
    </div>
  </div>
</div>

